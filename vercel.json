{
  "version": 2,
  "builds": [
    {
      "src": "api/fetch-emails.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ],
  "functions": {
    "api/fetch-emails.ts": {
      "maxDuration": 60
    }
  }
}